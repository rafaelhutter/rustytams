# RustyTAMS development credentials
# Copy to .env and modify as needed:  cp .env.example .env

# TAMS auth (used by web UI login and API calls)
TAMS_USERNAME=test
TAMS_PASSWORD=password
TAMS_API_KEY=test-api-key

# S3 object store (RustFS)
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin123

# Service ports
TAMS_PORT=5800
RUSTFS_PORT=9000
AUTH_PORT=5802
WEB_PORT=5803
